{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build image_compressor",
      "type": "shell",
      "command": "${workspaceFolder}\\build.bat",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ],
      "detail": "Press Ctrl+Shift+B to build the project on Windows without make."
    },
    {
      "label": "Clean image_compressor",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "if exist image_compressor.exe del /f /q image_compressor.exe"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
